generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(uuid())
  name             String
  email            String     @unique
  password         String
  role             String     @default("admin")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  resetToken       String?    @map("reset_token")
  resetTokenExpiry DateTime?  @map("reset_token_expiry")
  logs             AssetLog[]

  @@map("users")
}

model Asset {
  id String @id @default(uuid())

  // Kolom 1-8 dari Excel (data SAP)
  kodeKelas     String? @map("kode_kelas")
  kelasAsetSmbr String? @map("kelas_aset_smbr")
  kategoriSig   String? @map("kelas_aset_sig")
  nomorAset     String  @map("nomor_aset")
  namaAset      String  @map("nama_aset")
  site          String?
  qty           Int     @default(1)
  satuan        String? @default("PC")

  // Kolom Baru
  jenis String?
  merk  String?
  type  String?

  // Kolom 9: KOORDINAT
  latitude  Float?
  longitude Float?

  // Kolom 10: TANGGAL UPDATE
  tanggalUpdate DateTime? @map("tanggal_update")

  // Kolom 11: DOKUMENTASI
  fotoUrl String? @map("foto_url")

  // Kolom 12: KONDISI
  kondisi Kondisi @default(BELUM_DICEK)

  // Kolom 13: KETERANGAN
  keterangan String?

  // Kolom 14: QR CODE ASET
  qrCodeUrl String? @map("qr_code_url")

  // JSONB untuk custom columns yang dinamis
  customFields Json? @default("{}") @map("custom_fields")

  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")
  logs      AssetLog[]

  @@map("assets")
}

enum Kondisi {
  BAIK
  RUSAK
  RUSAK_BERAT
  HILANG
  BELUM_DICEK
}

model AssetLog {
  id        String   @id @default(uuid())
  assetId   String   @map("asset_id")
  userId    String?  @map("user_id")
  action    String   @db.VarChar(255)
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  catatan   String?
  createdAt DateTime @default(now()) @map("created_at")

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("asset_logs")
}
model AssetCustomColumn {
  id       String   @id @default(uuid())
  name     String   // "Nama Panjang Kolom" untuk UI
  key      String   @unique // "nama_kolom" (tanpa spasi/huruf besar) untuk key JSON
  type     String   @default("text") // "text", "number", "date", "boolean", "select"
  options  Json?    // Pilihan dropdown (jika type = "select"), e.g. ["A", "B", "C"]
  required Boolean  @default(false)
  order    Int      @default(0) // Urutan tampilan di UI

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("asset_custom_columns")
}